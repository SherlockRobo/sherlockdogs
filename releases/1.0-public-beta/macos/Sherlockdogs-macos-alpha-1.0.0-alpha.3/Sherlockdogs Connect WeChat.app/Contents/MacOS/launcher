#!/usr/bin/env bash
set -euo pipefail
root_dir="$(cd "$(dirname "$0")/../../.." && pwd)"
tmp="$(mktemp "/tmp/sherlockdogs-connect-wechat.XXXXXX.command")"
cat > "$tmp" <<SCRIPT
#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$root_dir"
cd "\$ROOT_DIR/packaging/macos-beta"
bash ./connect_wechat.sh
printf "\nPress Enter to close. "
read -r _
SCRIPT
chmod +x "$tmp"
open -a Terminal "$tmp"
