{
  "name": "Sherlockdogs Mac Alpha",
  "version": "1.0.0-alpha.3",
  "channel": "macos-beta",
  "entry": "wechat-self-plus-local-inbox",
  "default_inbox": "~/Sherlockdogs/Inbox",
  "recommended_cloud_inbox": "Nutstore WebDAV / synced folder",
  "recommended_cloud_inbox_path": "<Nutstore>/Sherlockdogs/Inbox",
  "default_vault_candidates": [
    "~/ObsidianVault_LOCAL",
    "~/Sherlockdogs/Vault"
  ],
  "services": [
    "com.sherlockdogs.local-inbox",
    "com.sherlockdogs.codex-runner"
  ],
  "supported_inputs": [
    "wechat article url",
    "x url",
    "xhs url",
    "bilibili url",
    "youtube url",
    "douyin url",
    "tiktok url",
    "image file",
    "video file",
    "pdf file",
    "plain text"
  ],
  "task_levels": {
    "#1": "archive only",
    "#2": "archive plus Codex card",
    "#3": "metadata/light parse in Codex",
    "#4": "deep read in Codex",
    "#5": "frames/screenshots/segments in Codex"
  },
  "privacy_model": "Mac WeChat self-chat is the recommended path after explicit opt-in; optional Inbox/Shortcut/synced folder is fallback; no Sherlockdogs relay by default",
  "beta_boundary": "Mac Personal Mode is opt-in via Sherlockdogs Connect WeChat.app",
  "cloud_boundary": "Nutstore is the user's own account; Sherlockdogs only watches the synced local folder",
  "first_run_entry": "Sherlockdogs Start.app",
  "wechat_entry": "Sherlockdogs Connect WeChat.app",
  "repair_entry": "Sherlockdogs OneTouchRepair.app",
  "doctor_entry": "Sherlockdogs Doctor.app",
  "output_entry": "Sherlockdogs Open Output.app"
}
